FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-autonomic.txt .
RUN pip install --no-cache-dir -r requirements-autonomic.txt

COPY pages/ ./pages/
COPY assets/ ./assets/
COPY autonomic/ ./autonomic/

EXPOSE 8501

CMD ["streamlit", "run", "pages/1_Dashboard.py", "--server.port=8501", "--server.address=0.0.0.0"]
